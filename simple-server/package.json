{
  "name": "simple-discord-server",
  "version": "1.0.0",
  "description": "Simple backend server for Discord Clone",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --legacy-watch server.js",
    "test": "jest --runInBand --forceExit --detectOpenHandles",
    "test:coverage": "jest --runInBand --forceExit --detectOpenHandles --coverage",
    "test:unit:coverage": "jest --runInBand --forceExit --detectOpenHandles --coverage --testPathIgnorePatterns=tests/integration",
    "test:docker": "docker compose -f ../docker-compose.yml run --rm backend sh -c \"npm install && npm test\"",
    "test:integration": "jest --runInBand --forceExit --detectOpenHandles --testPathPattern=integration",
    "package:lambda": "node scripts/package-lambda.cjs"
  },
  "devDependencies": {
    "archiver": "^7.0.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "serverless": "^3.40.0",
    "supertest": "^6.3.4"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.734.0",
    "@aws-sdk/client-dynamodb": "^3.734.0",
    "@aws-sdk/lib-dynamodb": "^3.734.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "serverless-http": "^3.2.0"
  }
}
