# Docker Compose reads most config from `docker-compose.yml`.
# Only secrets / local-only overrides should go here.
#
# Copy to `.env` and set your real Groq key:
#   cp .env.example .env
#
# Groq API (get key at https://console.groq.com - do not commit real key)
GROQ_API_KEY=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# PostgreSQL Configuration (use RDS / Neon / etc. in production; Lambda needs a reachable URL)
DATABASE_URL=postgresql://username:password@localhost:5432/discord-clone
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=discord-clone
DATABASE_USER=username
DATABASE_PASSWORD=password

# Optional: comma-separated origins for CORS (e.g. your Amplify app URL). Omit for permissive dev CORS.
# CORS_ORIGINS=https://main.d1234abcd.amplifyapp.com

# Optional overrides (normally keep defaults from docker-compose.yml)
GROQ_BASE_URL=https://api.groq.com
GROQ_MODEL_SUMMARY=llama-3.3-70b-versatile
GROQ_MODEL_PREVIEW=llama-3.1-8b-instant

# Realtime fanout (REST Lambda): set after deploying `serverless.yml` WebSocket stack.
# WS_MANAGEMENT_API_ENDPOINT=https://xxxx.execute-api.us-east-1.amazonaws.com/dev
# WS_CONNECTIONS_TABLE=discord-clone-realtime-dev-ws-connections
# WS_ROOM_MEMBERSHIPS_TABLE=discord-clone-realtime-dev-ws-room-memberships
