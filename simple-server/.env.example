# Environment Variables
PORT=3001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# PostgreSQL Configuration (use RDS / Neon / etc. in production; Lambda needs a reachable URL)
DATABASE_URL=postgresql://username:password@localhost:5432/discord-clone
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=discord-clone
DATABASE_USER=username
DATABASE_PASSWORD=password

# Optional: comma-separated origins for CORS (e.g. your Amplify app URL). Omit for permissive dev CORS.
# CORS_ORIGINS=https://main.d1234abcd.amplifyapp.com
